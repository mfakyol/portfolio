# =========================================================================
# HOST nginx (on the Linux server, NOT in a container).
# Terminates TLS for fatihakyol.com (+ www) and reverse-proxies to the
# portfolio container published on 127.0.0.1:8085.
#
# Install to /etc/nginx/sites-available/fatihakyol.com, symlink into
# sites-enabled, then:
#   sudo certbot --nginx -d fatihakyol.com -d www.fatihakyol.com
# certbot fills in the ssl_certificate lines and the port-443 blocks.
# =========================================================================

# Redirect http (apex + www) → https apex
server {
    listen 80;
    listen [::]:80;
    server_name fatihakyol.com www.fatihakyol.com;
    return 301 https://fatihakyol.com$request_uri;
}

# Redirect https www → https apex
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.fatihakyol.com;

    ssl_certificate     /etc/letsencrypt/live/fatihakyol.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fatihakyol.com/privkey.pem;

    return 301 https://fatihakyol.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name fatihakyol.com;

    ssl_certificate     /etc/letsencrypt/live/fatihakyol.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fatihakyol.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8085;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
